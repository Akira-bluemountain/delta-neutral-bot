# ========== 必須設定 ==========
# 以下 6 項目は必ず設定してください。未設定だと bot は起動しません。

# ----- Hyperliquid -----
# 取得方法: https://app.hyperliquid.xyz/API で「Generate」ボタンから
#   API Wallet (エージェントウォレット) を作成し、表示された情報をここに貼り付け
HL_API_WALLET_ADDRESS=
HL_API_WALLET_PRIVATE_KEY=

# ----- Extended (x10) -----
# 取得方法:
#   1. https://app.extended.exchange/ にログイン
#   2. 設定 → API 設定で「Create API Key」
#   3. 表示された API Key / Stark Private Key / Stark Public Key / Vault ID を貼り付け
EXTENDED_API_KEY=
EXTENDED_STARK_PRIVATE_KEY=
EXTENDED_STARK_PUBLIC_KEY=
EXTENDED_VAULT_ID=


# ========== 動作モード ==========
# 最初は必ず DRY_RUN=true（実注文なしのシミュレーション）で動作確認してください。
# ログと残高で問題なしを確認した後に false に切り替えて本番運用に移行します。
DRY_RUN=true


# ========== オプション（変更不要） ==========
# SQLite DB ファイルの保存先。通常変更不要。
# DB_PATH=./data/dn-engine.db
