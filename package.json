{
  "name": "delta-neutral-bot",
  "version": "1.0.0",
  "description": "Delta-neutral funding rate arbitrage bot for Hyperliquid x Extended",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && npm run build:copy-sql",
    "build:copy-sql": "mkdir -p dist/db/migrations && cp -f src/db/migrations/*.sql dist/db/migrations/ 2>/dev/null || true",
    "start": "node dist/index.js",
    "start:dry": "DRY_RUN=true node dist/index.js",
    "start:live": "DRY_RUN=false node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "keywords": [
    "hyperliquid",
    "extended",
    "x10",
    "funding-rate-arbitrage",
    "delta-neutral"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@msgpack/msgpack": "^3.1.3",
    "axios": "^1.14.0",
    "better-sqlite3": "^12.8.0",
    "dotenv": "^17.4.0",
    "ethers": "^6.16.0",
    "node-cron": "^4.2.1",
    "starknet": "^9.4.2",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.1",
    "@types/node-cron": "^3.0.11",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9"
  }
}
